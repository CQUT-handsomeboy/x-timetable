---
const { thisWeekTimetable } = Astro.props // 所有课表
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from '../components/ui/card'
import { Alert, AlertDescription, AlertTitle } from '../components/ui/alert'
import {weekDaysMapping} from "../lib/utils"

---

<Card>
  <CardHeader>
    <h1 class="text-2xl">🌼近日</h1>
  </CardHeader>
  <CardContent>
    <div class="flex flex-col gap-2">
      {
        thisWeekTimetable.map((table, index) => {
          if (table.length === 0) return

          return (
            <Alert>
              <AlertTitle>
                {weekDaysMapping[index]}
                {'  '}
              </AlertTitle>
              <AlertDescription>
                <div class="flex gap-5">
                  {table.map((t) => (
                    <div>{t.name}</div>
                  ))}
                </div>
              </AlertDescription>
            </Alert>
          )
        })
      }
    </div>
  </CardContent>
</Card>
